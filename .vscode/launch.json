{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run semver",
      "runtimeExecutable": "semver",
      "cwd": "${workspaceFolder}/node_modules/utf7",
      "args": []
    },
    {
      "name": "Launch Chrome",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run baseline-browser-mapping",
      "runtimeExecutable": "baseline-browser-mapping",
      "cwd": "${workspaceFolder}/src/frontend",
      "args": []
    },
    {
      "name": "🚀 HelpPilot",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/server.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "preLaunchTask": "Kill port 3000",
      "env": {
        "NODE_ENV": "development"
      }
    }
  ]
}