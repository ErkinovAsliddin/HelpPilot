# HelpPilot Environment Variables
# Copy this file to .env and fill in your values

# ── API Authentication ──────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for the admin dashboard and API clients
HELPPILOT_API_KEYS=your-secret-api-key-here

# ── AWS / Bedrock ────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# Claude 3.5 Sonnet model ID:
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# ── ChromaDB ─────────────────────────────────────────────────────────────────────
CHROMA_URL=http://chromadb:8000    # not localhost — "chromadb" is the compose service name
DB_PATH=/app/data/helppilot.db     # points into the mounted volume so data survives restarts

# ── Brave Search API (optional — enables web fallback when KB score < 0.5) ──────
BRAVE_API_KEY=your-brave-api-key

# ── Email / SMTP ─────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=helppilot@yourcompany.com
ADMIN_EMAIL=admin@yourcompany.com

# SendGrid alternative (leave blank to use SMTP above)
SENDGRID_API_KEY=

# ── IMAP (for email ticket ingestion) ────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=helpdesk@yourcompany.com
IMAP_PASS=your-imap-password

# ── Slack Notifications ──────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
LEAD_NOTIFICATION_CHANNEL=https://hooks.slack.com/services/YOUR/LEAD/WEBHOOK

# ── Whisper (optional audio transcription endpoint) ──────────────────────────────
# Leave blank to use AWS Transcribe instead
WHISPER_ENDPOINT=

# ── Server ───────────────────────────────────────────────────────────────────────
PORT=3000
DB_PATH=./helppilot.db

# ── Business Hours (for urgency Slack pings) ─────────────────────────────────────
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=17:00

# ── Prediction Engine ────────────────────────────────────────────────────────────
PREDICTION_INTERVAL_MS=30000
INCIDENT_WINDOW_MS=300000

# ── Session Metrics ──────────────────────────────────────────────────────────────
AVG_HANDLING_TIME_MINUTES=5.0
COST_PER_HOUR_USD=50.0
